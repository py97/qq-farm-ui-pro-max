# =====================================================
# QQ 农场智能助手 - 环境变量配置
# =====================================================
# 说明：修改下方变量后运行 docker compose up -d 即可启动
# =====================================================

# ========== 必改项 ==========

# Web 管理后台密码（登录用）
ADMIN_PASSWORD=qq007qq008

# ========== 可选项（通常不需要修改） ==========

# Web 对外端口（默认 3080）
WEB_PORT=3080

# MySQL 配置
MYSQL_ROOT_PASSWORD=qq007qq008
MYSQL_DATABASE=qq_farm
MYSQL_USER=qq_farm_user
MYSQL_PASSWORD=qq007qq008

# 日志级别（debug / info / warn / error）
LOG_LEVEL=info

# 时区（默认上海）
TZ=Asia/Shanghai
